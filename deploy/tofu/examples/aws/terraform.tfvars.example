# Copy this file to terraform.tfvars and fill in the values.
# Do NOT commit terraform.tfvars — it contains secrets.

aws_region       = "eu-central-1"
# nebu_version: SemVer tag without the 'v' prefix (e.g. "1.0.0" for Git tag v1.0.0).
# The release pipeline pushes images as:
#   <image_registry>/nebu-gateway:<nebu_version>
#   <image_registry>/nebu-core:<nebu_version>
# Never use "latest" — the module validates this and will reject it.
nebu_version     = "1.0.0"
domain_name      = "chat.example.com"
admin_email      = "admin@example.com"
postgres_db_name = "nebu"
# image_registry: container registry prefix where release images are pushed.
# Set this to your fork's registry path (e.g. registry.gitlab.com/myorg/open-chat).
image_registry   = "registry.gitlab.com/myorg/open-chat"
vpc_cidr         = "10.0.0.0/16"
environment      = "prod"

# RDS / Aurora Serverless v2
# Aurora Serverless v2 capacity (ACUs — 0 = scale to zero, 4 = max burst)
# aurora_min_capacity = 0
# aurora_max_capacity = 4
db_password         = "REPLACE_ME_with_a_strong_password"
skip_final_snapshot = false

# ALB HTTPS listener certificate (ACM ARN, same region as ALB)
# Leave empty ("") for validate-only runs (tofu validate does not require a real ARN).
acm_certificate_arn = ""

# Number of desired ECS tasks for gateway and core services.
ecs_desired_count = 2

# ── DNS ──────────────────────────────────────────────────────────────────────
# dns_mode = "default" creates a Route 53 A-record (ALIAS) pointing domain_name to the ALB.
# Requires a Route 53 hosted zone named *exactly* domain_name (e.g. "chat.example.com").
# A parent zone (e.g. "example.com") will NOT match — the zone name must be identical to domain_name.
# dns_mode = "external" (default) skips DNS creation — register the 'dns_name' output
# value as a CNAME in your DNS provider. Note: CNAME records are not supported at the zone
# apex (e.g., "example.com"). For apex domains, use an ALIAS record (Route 53) or
# equivalent in your DNS provider.
dns_mode = "external"  # or: "default"
