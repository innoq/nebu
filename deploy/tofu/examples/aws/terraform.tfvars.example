# Copy this file to terraform.tfvars and fill in the values.
# Do NOT commit terraform.tfvars — it contains secrets.

aws_region       = "eu-central-1"
nebu_version     = "0.3.0"
domain_name      = "chat.example.com"
admin_email      = "admin@example.com"
postgres_db_name = "nebu"
image_registry   = "registry.gitlab.com/myorg/open-chat"
vpc_cidr         = "10.0.0.0/16"
environment      = "prod"

# RDS
db_instance_class   = "db.t3.medium"
db_password         = "REPLACE_ME_with_a_strong_password"
skip_final_snapshot = false

# ALB HTTPS listener certificate (ACM ARN, same region as ALB)
# Leave empty ("") for validate-only runs (tofu validate does not require a real ARN).
acm_certificate_arn = ""

# Number of desired ECS tasks for gateway and core services.
ecs_desired_count = 2
